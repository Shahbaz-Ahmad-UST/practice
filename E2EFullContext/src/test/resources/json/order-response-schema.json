{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Order Response Contract",
  "type": "object",
  "required": ["id", "cartId", "status", "totalPaise", "address"],
  "properties": {
    "id": { "type": "integer" },
    "cartId": { "type": "integer" },
    "status": {
      "type": "string",
      "enum": ["OPEN", "PLACED", "CANCELLED"]
    },
    "totalPaise": { "type": "integer", "minimum": 0 },
    "address": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": true
}